generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MEMBER
}

enum PipelineStage {
  NEW_LEAD
  QUALIFIED
  DISCOVERY_CALL
  DISCOVERY_DONE
  PROPOSAL_SENT
  FOLLOW_UP
  WON
  LOST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Urgency {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  CALL
  MEETING
  EMAIL
  PROPOSAL_SENT
  FOLLOW_UP
  INVOICE
  PAYMENT
  STATUS_CHANGE
  NOTE
}

enum VisualStyle {
  CLEAN
  MODERN
  HIGHLIGHT
  MINIMAL
  HERO
  TWO_COLUMN
}

enum LayoutType {
  FULL_WIDTH
  CENTERED
  TWO_COLUMN
  CARD
}

enum ProposalSectionType {
  COVER
  EXECUTIVE_SUMMARY
  PROBLEM_STATEMENT
  PROPOSED_SOLUTION
  SCOPE_OF_WORK
  TIMELINE
  PRICING
  ABOUT_US
  TERMS
  NEXT_STEPS
  CUSTOM
}

enum ProposalStatus {
  DRAFT
  REVIEW
  SENT
  ACCEPTED
  DECLINED
}

enum TranscriptSource {
  MANUAL
  GOOGLE_MEET
  ZOOM
}

enum InvoiceType {
  FULL_PAYMENT
  ADVANCE_PAYMENT
  MILESTONE_PAYMENT
  FINAL_PAYMENT
}

enum PaymentTerms {
  DUE_ON_RECEIPT
  DAYS_7
  DAYS_14
  DAYS_30
  CUSTOM
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum ServiceStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  WAITING
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskRelatedType {
  LEAD
  INVOICE
  RECEIPT
  SERVICE
  GENERAL
}

enum TaskSource {
  MANUAL
  AI_SUGGESTED
  RECURRING
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  name      String?
  email     String   @unique
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model Lead {
  id String @id @default(cuid())

  // Contact
  name        String
  companyName String? @map("company_name")
  phone       String?
  email       String?

  // Lead context
  source            String?
  serviceInterested String? @map("service_interested")
  callVolume        String? @map("call_volume")
  industry          String?
  teamSize          String? @map("team_size")

  // Online presence
  socialProfiles  String? @map("social_profiles")
  existingWebsite String? @map("existing_website")

  // Discovery
  currentProblem String? @map("current_problem")
  currentTools   String? @map("current_tools")

  // Status
  priority      Priority      @default(MEDIUM)
  urgency       Urgency       @default(MEDIUM)
  pipelineStage PipelineStage @default(NEW_LEAD) @map("pipeline_stage")

  // Timeline
  lastContacted DateTime? @map("last_contacted")
  nextFollowUp  DateTime? @map("next_follow_up")

  // Deal
  dealValue    Float?  @map("deal_value")
  proposalSent Boolean @default(false) @map("proposal_sent")

  // Internal
  notes      String? // quick internal memo (from edit form)
  assignedTo String? @map("assigned_to")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  noteEntries        Note[]
  activities         Activity[]
  tasks              Task[]
  followUps          FollowUp[]
  proposals          Proposal[]
  meetingTranscripts MeetingTranscript[]
  invoices           Invoice[]
  receipts           Receipt[]

  @@map("leads")
}

model Note {
  id        String   @id @default(cuid())
  leadId    String   @map("lead_id")
  content   String
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("notes")
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String       @map("lead_id")
  type        ActivityType
  description String
  link        String?
  createdBy   String?      @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("activities")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  assignedTo  String?      @map("assigned_to")
  createdBy   String?      @map("created_by")
  completedAt DateTime?    @map("completed_at")

  relatedType TaskRelatedType @default(GENERAL) @map("related_type")
  leadId      String?         @map("lead_id")
  invoiceId   String?         @map("invoice_id")
  receiptId   String?         @map("receipt_id")
  serviceId   String?         @map("service_id")

  source   TaskSource @default(MANUAL)
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receipt Receipt? @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  comments TaskComment[]

  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([relatedType])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  content   String
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_comments")
}

model FollowUp {
  id          String    @id @default(cuid())
  leadId      String    @map("lead_id")
  title       String
  notes       String?
  dueDate     DateTime  @map("due_date")
  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")
  assignedTo  String?   @map("assigned_to")
  templateId  String?   @map("template_id")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  lead     Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template FollowUpTemplate? @relation(fields: [templateId], references: [id])

  @@map("follow_ups")
}

model FollowUpTemplate {
  id        String     @id @default(cuid())
  name      String     @unique
  title     String
  notes     String?
  followUps FollowUp[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("follow_up_templates")
}

// ─── Proposal System ──────────────────────────────────────────────────────────

model ProposalTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sections  ProposalTemplateSection[]
  proposals Proposal[]

  @@map("proposal_templates")
}

model ProposalTemplateSection {
  id             String              @id @default(cuid())
  templateId     String              @map("template_id")
  type           ProposalSectionType
  title          String
  templateText   String              @default("") @map("template_text")
  aiInstructions String?             @map("ai_instructions")
  order          Int
  isRequired     Boolean             @default(true) @map("is_required")
  isAIGenerated  Boolean             @default(false) @map("is_ai_generated")
  isAIRefinement Boolean             @default(false) @map("is_ai_refinement")
  visualStyle    VisualStyle         @default(CLEAN) @map("visual_style")
  layoutType     LayoutType          @default(FULL_WIDTH) @map("layout_type")
  metadata       Json?
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  template ProposalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("proposal_template_sections")
}

model Proposal {
  id         String         @id @default(cuid())
  leadId     String         @map("lead_id")
  templateId String?        @map("template_id")
  title      String
  status     ProposalStatus @default(DRAFT)
  validUntil DateTime?      @map("valid_until")
  totalValue Float?         @map("total_value")
  createdBy  String?        @map("created_by")
  sentAt     DateTime?      @map("sent_at")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  lead     Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template ProposalTemplate? @relation(fields: [templateId], references: [id])
  sections ProposalSection[]
  invoices Invoice[]

  @@map("proposals")
}

model ProposalSection {
  id            String              @id @default(cuid())
  proposalId    String              @map("proposal_id")
  type          ProposalSectionType
  title         String
  content       String              @default("")
  order         Int
  isAIGenerated Boolean             @default(false) @map("is_ai_generated")
  isVisible     Boolean             @default(true) @map("is_visible")
  visualStyle   VisualStyle         @default(CLEAN) @map("visual_style")
  layoutType    LayoutType          @default(FULL_WIDTH) @map("layout_type")
  metadata      Json?
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@map("proposal_sections")
}

// ─── Meeting Transcripts ──────────────────────────────────────────────────────

model MeetingTranscript {
  id          String           @id @default(cuid())
  leadId      String           @map("lead_id")
  rawText     String?          @map("raw_text")
  insights    Json
  source      TranscriptSource @default(MANUAL)
  processedAt DateTime         @default(now()) @map("processed_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("meeting_transcripts")
}

// ─── Service Catalog ──────────────────────────────────────────────────────────

model Service {
  id String @id @default(cuid())

  // Core Info
  name             String
  category         String
  status           ServiceStatus @default(ACTIVE)
  shortDescription String        @map("short_description")
  fullDescription  String?       @map("full_description")

  // Pricing
  startingPrice Float? @map("starting_price")
  defaultPrice  Float? @map("default_price")
  pricingNotes  String? @map("pricing_notes")

  // Delivery
  timeline            String?
  deliverables        String?
  implementationSteps String? @map("implementation_steps")

  // Sales
  idealClient      String? @map("ideal_client")
  problemsSolved   String? @map("problems_solved")
  commonObjections String? @map("common_objections")

  // AI
  aiContext            String? @map("ai_context")
  proposalInstructions String? @map("proposal_instructions")
  followUpInstructions String? @map("follow_up_instructions")

  // Templates
  proposalDefaults String? @map("proposal_defaults")
  invoiceDefaults  String? @map("invoice_defaults")

  // Internal
  notes String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tasks Task[]

  @@unique([name])
  @@index([status])
  @@index([category])
  @@map("services")
}

// ─── Settings System ──────────────────────────────────────────────────────────

model AgencySettings {
  id String @id @default("1")

  // Business
  businessName String? @map("business_name")
  website      String?
  email        String?
  phone        String?
  address      String?
  gstNumber    String? @map("gst_number")
  tagline      String?

  // Branding
  logoUrl          String? @map("logo_url")
  primaryColor     String? @map("primary_color")
  secondaryColor   String? @map("secondary_color")
  accentColor      String? @map("accent_color")
  brandDescription String? @map("brand_description")

  // Payments
  bankName            String? @map("bank_name")
  accountHolder       String? @map("account_holder")
  accountNumber       String? @map("account_number")
  ifscCode            String? @map("ifsc_code")
  upiId               String? @map("upi_id")
  paymentInstructions String? @map("payment_instructions")

  // AI
  defaultTone          String? @map("default_tone")
  defaultProposalStyle String? @map("default_proposal_style")
  defaultFollowUpStyle String? @map("default_follow_up_style")
  aiBrandVoice         String? @map("ai_brand_voice")

  // Service Preferences
  defaultServiceId   String? @map("default_service_id")
  featuredServiceIds Json?   @map("featured_service_ids")
  serviceOrdering    String? @map("service_ordering")

  // Pipeline
  pipelineStageLabels Json?   @map("pipeline_stage_labels")
  defaultWonStage     String? @default("WON") @map("default_won_stage")
  defaultLostStage    String? @default("LOST") @map("default_lost_stage")

  // Legacy (preserved)
  name        String?
  bankDetails String? @map("bank_details")
  terms       String?
  toneOfVoice String? @map("tone_of_voice")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("agency_settings")
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  email     String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("team_members")
}

// ─── Invoice System ──────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique @map("invoice_number")
  leadId         String        @map("lead_id")
  proposalId     String?       @map("proposal_id")
  
  type           InvoiceType
  status         InvoiceStatus @default(DRAFT)
  
  issueDate      DateTime      @map("issue_date")
  dueDate        DateTime      @map("due_date")
  
  // Client Info Snapshot
  clientName     String        @map("client_name")
  companyName    String?       @map("company_name")
  email          String?
  phone          String?
  billingAddress String?       @map("billing_address")
  
  // GST Info
  gstEnabled     Boolean       @default(false) @map("gst_enabled")
  gstNumber      String?       @map("gst_number")
  gstPercentage  Float?        @map("gst_percentage")
  
  // Notes & Info
  bankDetails    String?       @map("bank_details")
  terms          String?
  notes          String?
  internalNotes  String?       @map("internal_notes")
  
  // Totals
  subtotal        Float
  discountAmount  Float         @default(0) @map("discount_amount")
  gstAmount       Float         @default(0) @map("gst_amount")
  grandTotal      Float         @map("grand_total")
  paymentTerms   PaymentTerms  @default(DUE_ON_RECEIPT) @map("payment_terms")
  
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  lead           Lead          @relation(fields: [leadId], references: [id])
  proposal       Proposal?     @relation(fields: [proposalId], references: [id])
  items          InvoiceItem[]
  receipts       Receipt[]
  tasks          Task[]

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String   @map("invoice_id")
  description String
  quantity    Int
  unitPrice   Float    @map("unit_price")
  total       Float
  
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ─── Receipt System ──────────────────────────────────────────────────────────

model Receipt {
  id                   String   @id @default(cuid())
  receiptNumber        String   @unique @map("receipt_number")
  receiptDate          DateTime @map("receipt_date")
  
  invoiceId            String?  @map("invoice_id")
  leadId               String   @map("lead_id")
  
  // Snapshot
  clientName           String   @map("client_name")
  companyName          String?  @map("company_name")
  
  amountReceived       Float    @map("amount_received")
  paymentDate          DateTime @map("payment_date")
  paymentMethod        String?  @map("payment_method")
  transactionReference String?  @map("transaction_reference")
  utrNumber            String?  @map("utr_number")
  notes                String?
  terms                String?
  
  services             String   // Comma separated list of services paid for
  
  invoice              Invoice? @relation(fields: [invoiceId], references: [id])
  lead                 Lead     @relation(fields: [leadId], references: [id])
  tasks                Task[]

  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("receipts")
}
